{
  "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/nicegui/cli/config/tauri.schema.json",
  "productName": "zkguard",
  "version": "0.2.0",
  "identifier": "com.zkguard.desktop",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "title": "zkguard",
    "windows": [
      {
        "title": "zkguard — API Key Protection",
        "width": 800,
        "height": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
